# ============================================================================
# GOOGLE ADS API CREDENTIALS
# ============================================================================
# Get these from: https://developers.google.com/google-ads/api/docs/first-call/overview

# OAuth2 Client ID (from Google Cloud Console)
GOOGLE_ADS_CLIENT_ID=your_client_id_here

# OAuth2 Client Secret (from Google Cloud Console)
GOOGLE_ADS_CLIENT_SECRET=your_client_secret_here

# Developer Token (from Google Ads API Center)
GOOGLE_ADS_DEVELOPER_TOKEN=your_developer_token_here

# Refresh Token (generated using OAuth2 flow)
GOOGLE_ADS_REFRESH_TOKEN=your_refresh_token_here

# Customer ID (your Google Ads account ID, format: 123-456-7890)
GOOGLE_ADS_CUSTOMER_ID=123-456-7890

# ============================================================================
# EXISTING VARIABLES (already in your .env)
# ============================================================================
# Anthropic Claude API Key
ANTHROPIC_API_KEY=your_key_here
CLAUDE_API_KEY=your_key_here

# Supabase Configuration
VITE_SUPABASE_URL=your_url_here
VITE_SUPABASE_ANON_KEY=your_key_here
SUPABASE_SERVICE_ROLE_KEY=your_key_here

# Stripe Configuration
VITE_STRIPE_PUBLISHABLE_KEY=your_key_here
STRIPE_SECRET_KEY=your_key_here

# ... etc
